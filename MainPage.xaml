<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KiirLink.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    Title="Home">

    <Grid RowDefinitions="*,Auto">
        <Grid
            Grid.Row="0"
            Padding="24,8,24,18"
            RowDefinitions="Auto,*">
            <controls:AppHeader Grid.Row="0" />

            <VerticalStackLayout
                Grid.Row="1"
                Spacing="16"
                VerticalOptions="Center">
                <Image
                    Margin="4,0,4,10"
                    Aspect="AspectFit"
                    HeightRequest="178"
                    Source="home_hero.png" />

                <Border
                    Padding="0"
                    Style="{StaticResource CardBorder}">
                    <Grid ColumnDefinitions="92,*,40" HeightRequest="42">
                        <Border
                            BackgroundColor="#F2F2F2"
                            Padding="10,0"
                            Stroke="{StaticResource CardStroke}"
                            StrokeShape="RoundRectangle 10,0,0,10">
                            <Label
                                FontSize="11"
                                Text="kiirlink.ee/"
                                TextColor="{StaticResource BrandText}"
                                VerticalTextAlignment="Center" />
                        </Border>
                        <Entry
                            x:Name="CustomLinkEntry"
                            Grid.Column="1"
                            Margin="4,0"
                            Placeholder="your-custom-link"
                            ReturnType="Done" />
                        <Image
                            Grid.Column="2"
                            HeightRequest="20"
                            HorizontalOptions="Center"
                            Source="link.png"
                            VerticalOptions="Center"
                            WidthRequest="20" />
                    </Grid>
                </Border>

                <Button
                    Clicked="OnContinueClicked"
                    Style="{StaticResource PrimaryButton}"
                    Text="CONTINUE" />
            </VerticalStackLayout>
        </Grid>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Home" />
    </Grid>

</ContentPage>
