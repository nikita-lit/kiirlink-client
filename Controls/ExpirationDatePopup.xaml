<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup
    x:Class="KiirLink.Controls.ExpirationDatePopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:KiirLink.Extensions"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="Transparent"
    CanBeDismissedByTappingOutsideOfPopup="True"
    Padding="0">

    <Border
        BackgroundColor="{DynamicResource AppSurface}"
        Padding="18"
        Stroke="{DynamicResource AppStroke}"
        StrokeShape="RoundRectangle 14">
        <VerticalStackLayout Spacing="14" WidthRequest="310">
            <Label
                FontFamily="RadioCanadaBigSemiBold"
                FontSize="16"
                Text="{l:Translate AutoExpiration}"
                TextColor="{DynamicResource AppText}" />

            <Label
                FontSize="11"
                Text="{l:Translate ExpirationHelp}"
                TextColor="{DynamicResource AppMutedText}" />

            <DatePicker
                x:Name="ExpirationPicker"
                Format="MMM d, yyyy" />

            <Grid ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                <Button
                    Clicked="OnNeverClicked"
                    Style="{StaticResource OutlineButton}"
                    Text="{l:Translate Never}" />
                <Button
                    Grid.Column="1"
                    Clicked="OnCancelClicked"
                    Style="{StaticResource OutlineButton}"
                    Text="{l:Translate Cancel}" />
                <Button
                    Grid.Column="2"
                    Clicked="OnSaveClicked"
                    Style="{StaticResource PrimaryButton}"
                    Text="{l:Translate Save}" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
