<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="KiirLink.Controls.LinkCard"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Border
        MinimumHeightRequest="70"
        Padding="{StaticResource CardPadding}"
        AutomationProperties.IsInAccessibleTree="True"
        Style="{StaticResource CardBorder}">
        <Grid
            ColumnDefinitions="64,*,Auto"
            RowDefinitions="22,20,22"
            ColumnSpacing="12"
            VerticalOptions="Center">

            <!-- Tap for menu on entire card -->
            <BoxView
                Grid.ColumnSpan="3"
                Grid.RowSpan="3"
                BackgroundColor="Transparent"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="OnCardTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Link Icon -->
            <Image
                Grid.RowSpan="3"
                HeightRequest="52"
                HorizontalOptions="Start"
                Source="documenticon.png"
                SemanticProperties.Description="Link document"
                VerticalOptions="Center"
                WidthRequest="52">
                <Image.Behaviors>
                    <toolkit:IconTintColorBehavior TintColor="{DynamicResource AppMutedText}" />
                </Image.Behaviors>
            </Image>

            <!-- Title -->
            <Label
                Grid.Column="1"
                FontFamily="RadioCanadaBigSemiBold"
                FontSize="14"
                LineBreakMode="TailTruncation"
                Text="{Binding Title, Source={x:Reference Root}}" />

            <!-- URL -->
            <Label
                Grid.Row="1"
                Grid.Column="1"
                FontSize="11"
                LineBreakMode="TailTruncation"
                Text="{Binding Url, Source={x:Reference Root}}"
                TextColor="{DynamicResource AppMutedText}" />

            <!-- Stats -->
            <Grid
                Grid.Row="2"
                Grid.Column="1"
                ColumnDefinitions="Auto,Auto,Auto,Auto"
                ColumnSpacing="12"
                VerticalOptions="Center">
                <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                    <Image HeightRequest="16" Source="bar_chart.png" WidthRequest="16">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{DynamicResource AppMutedText}" />
                        </Image.Behaviors>
                    </Image>
                    <Label
                        FontSize="10"
                        Text="{Binding Clicks, Source={x:Reference Root}, StringFormat='{0} clicks'}"
                        VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Image HeightRequest="15" Source="calendar.png" WidthRequest="15">
                        <Image.Behaviors>
                            <toolkit:IconTintColorBehavior TintColor="{DynamicResource AppMutedText}" />
                        </Image.Behaviors>
                    </Image>
                    <Label
                        FontSize="10"
                        Text="{Binding Date, Source={x:Reference Root}}"
                        VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Category and favourite indicator -->
            <HorizontalStackLayout
                Grid.Row="0"
                Grid.Column="2"
                Spacing="5"
                HorizontalOptions="End"
                VerticalOptions="Start">

                <Border
                    x:Name="CategoryBadge"
                    BackgroundColor="{DynamicResource AppCategorySurface}"
                    Padding="7,2"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8">
                    <Label
                        x:Name="CategoryLabel"
                        FontSize="10"
                        Text="{Binding Category, Source={x:Reference Root}}"
                        TextColor="{DynamicResource AppCategoryText}" />
                </Border>

                <Border
                    x:Name="FavouriteIndicator"
                    BackgroundColor="{DynamicResource AppDangerSurface}"
                    HeightRequest="22"
                    Padding="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 11"
                    WidthRequest="22">
                    <Image
                        HeightRequest="17"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Favourite link"
                        Source="like.png"
                        VerticalOptions="Center"
                        WidthRequest="17" />
                </Border>
            </HorizontalStackLayout>

            <!-- More Menu Icon -->
            <Image
                x:Name="MoreIcon"
                Grid.Row="2"
                Grid.Column="2"
                HeightRequest="20"
                HorizontalOptions="End"
                IsVisible="{Binding ShowActions, Source={x:Reference Root}}"
                Source="more_vert.svg"
                AutomationProperties.IsInAccessibleTree="True"
                SemanticProperties.Description="Open link actions"
                VerticalOptions="Center"
                WidthRequest="20">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMoreIconTapped" />
                </Image.GestureRecognizers>
            </Image>
        </Grid>
    </Border>

</ContentView>
