<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="KiirLink.Controls.LinkCard"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        MinimumHeightRequest="70"
        Padding="14,10"
        Style="{StaticResource CardBorder}">
        <Grid
            ColumnDefinitions="64,*,Auto"
            RowDefinitions="22,20,22"
            ColumnSpacing="12"
            VerticalOptions="Center">

            <!-- Tap for menu on entire card -->
            <BoxView
                Grid.ColumnSpan="3"
                Grid.RowSpan="3"
                BackgroundColor="Transparent"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="OnCardTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Link Icon -->
            <Image
                Grid.RowSpan="3"
                HeightRequest="52"
                HorizontalOptions="Start"
                Source="documenticon.png"
                VerticalOptions="Center"
                WidthRequest="52" />

            <!-- Title -->
            <Label
                Grid.Column="1"
                FontFamily="RadioCanadaBigSemiBold"
                FontSize="14"
                LineBreakMode="TailTruncation"
                Text="{Binding Title, Source={x:Reference Root}}" />

            <!-- URL -->
            <Label
                Grid.Row="1"
                Grid.Column="1"
                FontSize="11"
                LineBreakMode="TailTruncation"
                Text="{Binding Url, Source={x:Reference Root}}"
                TextColor="{StaticResource MutedText}" />

            <!-- Stats -->
            <Grid
                Grid.Row="2"
                Grid.Column="1"
                ColumnDefinitions="Auto,Auto,Auto,Auto"
                ColumnSpacing="12"
                VerticalOptions="Center">
                <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                    <Image HeightRequest="16" Source="bar_chart.png" WidthRequest="16" />
                    <Label
                        FontSize="10"
                        Text="{Binding Views, Source={x:Reference Root}, StringFormat='{0} views'}"
                        VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Image HeightRequest="15" Source="calendar.png" WidthRequest="15" />
                    <Label
                        FontSize="10"
                        Text="{Binding Date, Source={x:Reference Root}}"
                        VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Category and favorite badges -->
            <Border
                x:Name="CategoryBadge"
                Grid.Row="0"
                Grid.Column="2"
                BackgroundColor="{StaticResource SoftGreen}"
                Padding="7,2"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 8"
                HorizontalOptions="End"
                VerticalOptions="Start">
                <Label
                    x:Name="CategoryLabel"
                    FontSize="10"
                    Text="{Binding Category, Source={x:Reference Root}}"
                    TextColor="{StaticResource GreenText}" />
            </Border>

            <Border
                x:Name="FavouriteBadge"
                Grid.Row="1"
                Grid.Column="2"
                BackgroundColor="{StaticResource SoftRed}"
                HeightRequest="38"
                IsVisible="False"
                Padding="0"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 19"
                HorizontalOptions="End"
                VerticalOptions="Center"
                WidthRequest="38">
                <Image
                    HeightRequest="35"
                    HorizontalOptions="Center"
                    Source="like.png"
                    VerticalOptions="Center"
                    WidthRequest="35" />
            </Border>

            <!-- More Menu Icon -->
            <Image
                x:Name="MoreIcon"
                Grid.Row="2"
                Grid.Column="2"
                HeightRequest="20"
                HorizontalOptions="End"
                Source="more_vert.png"
                VerticalOptions="Center"
                WidthRequest="20">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMoreIconTapped" />
                </Image.GestureRecognizers>
            </Image>
        </Grid>
    </Border>

</ContentView>