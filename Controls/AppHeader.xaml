<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="KiirLink.Controls.AppHeader"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid HeightRequest="62" ColumnDefinitions="52,*,52">
        <Image
            Grid.Column="0"
            HeightRequest="44"
            HorizontalOptions="Start"
            Source="kiirlink_logo.png"
            WidthRequest="44" />

        <HorizontalStackLayout
            Grid.Column="1"
            HorizontalOptions="Center"
            Spacing="0"
            VerticalOptions="Center">
            <Label
                FontFamily="RadioCanadaBigSemiBold"
                FontSize="20"
                Text="Kiir"
                TextColor="{StaticResource BrandText}" />
            <Label
                FontFamily="RadioCanadaBigSemiBold"
                FontSize="20"
                Text="Link"
                TextColor="{StaticResource BrandOrange}" />
        </HorizontalStackLayout>
    </Grid>

</ContentView>