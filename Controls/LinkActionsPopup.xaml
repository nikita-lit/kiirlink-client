<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup
    x:Class="KiirLink.Controls.LinkActionsPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="Transparent"
    Padding="0"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border
        Padding="14"
        Stroke="{DynamicResource AppStroke}"
        StrokeShape="RoundRectangle 14"
        BackgroundColor="{DynamicResource AppSurface}">
        <VerticalStackLayout Spacing="8" WidthRequest="340">
            <Label
                FontFamily="RadioCanadaBigSemiBold"
                FontSize="14"
                Text="Link actions"
                TextColor="{DynamicResource AppText}" />

            <Button
                Clicked="OnCopyShortClicked"
                ContentLayout="Left,8"
                ImageSource="copy.svg"
                Style="{StaticResource PrimaryButton}"
                Text="Copy short link" />

            <Button
                Clicked="OnCreateQRCodeClicked"
                ContentLayout="Left,8"
                ImageSource="qr_code.svg"
                Style="{StaticResource PrimaryButton}"
                Text="Create QR Code" />

            <BoxView
                Margin="0,4"
                BackgroundColor="{DynamicResource AppDivider}"
                HeightRequest="1" />

            <Button
                Clicked="OnCopyOriginalClicked"
                ContentLayout="Left,8"
                ImageSource="action_link.svg"
                Style="{StaticResource OutlineButton}"
                Text="Copy original link" />

            <Button
                Clicked="OnAnalyticsClicked"
                ContentLayout="Left,8"
                ImageSource="action_analytics.svg"
                Style="{StaticResource OutlineButton}"
                Text="View analytics" />

            <Button
                x:Name="CategoryButton"
                Clicked="OnAssignCategoryClicked"
                ContentLayout="Left,8"
                ImageSource="action_category.svg"
                Style="{StaticResource OutlineButton}"
                Text="Assign category" />

            <Button
                x:Name="FavouriteButton"
                Clicked="OnFavouriteClicked"
                ContentLayout="Left,8"
                ImageSource="action_favourite.svg"
                Style="{StaticResource OutlineButton}"
                Text="Add to favourites" />

            <BoxView
                Margin="0,4"
                BackgroundColor="{DynamicResource AppDivider}"
                HeightRequest="1" />

            <Button
                BackgroundColor="{DynamicResource AppDangerSurface}"
                BorderColor="{DynamicResource AppDangerStroke}"
                Clicked="OnDeleteClicked"
                ContentLayout="Left,8"
                ImageSource="action_delete.svg"
                Style="{StaticResource OutlineButton}"
                Text="Delete"
                TextColor="{DynamicResource AppDangerText}" />

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
