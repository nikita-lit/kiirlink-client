<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup
    x:Class="KiirLink.Controls.CategoryManagementPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:KiirLink.Extensions"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="Transparent"
    Padding="0"
    CanBeDismissedByTappingOutsideOfPopup="True">

    <Border
        Padding="14"
        Stroke="{DynamicResource AppStroke}"
        StrokeShape="RoundRectangle 14"
        BackgroundColor="{DynamicResource AppSurface}">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12" WidthRequest="340" HeightRequest="400">
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label
                    FontFamily="RadioCanadaBigSemiBold"
                    FontSize="16"
                    Text="{l:Translate ManageCategories}"
                    TextColor="{DynamicResource AppText}" />
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry
                    x:Name="NewCategoryEntry"
                    Placeholder="{l:Translate NewCategory}"
                    ReturnType="Done" />
                <Button
                    Grid.Column="1"
                    Clicked="OnCreateClicked"
                    ContentLayout="Left,6"
                    MinimumHeightRequest="38"
                    Style="{StaticResource PrimaryButton}"
                    Text="{l:Translate Add}" />
            </Grid>

            <Grid Grid.Row="2">
                <CollectionView x:Name="CategoriesCollection" ItemsSource="{Binding Categories}">
                    <CollectionView.EmptyView>
                        <Label
                            HorizontalTextAlignment="Center"
                            Margin="0,18"
                            Style="{StaticResource MutedLabel}"
                            Text="{l:Translate NoCategoriesYet}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="12,10"
                                Style="{StaticResource CardBorder}">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label
                                        FontFamily="RadioCanadaBigSemiBold"
                                        FontSize="12"
                                        VerticalTextAlignment="Center"
                                        Text="{Binding Name}" />
                                    <Button
                                        Grid.Column="1"
                                        Clicked="OnDeleteCategoryClicked"
                                        CommandParameter="{Binding .}"
                                        MinimumHeightRequest="30"
                                        Padding="10,4"
                                        Style="{StaticResource OutlineButton}"
                                        Text="{l:Translate Delete}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <Label
                Grid.Row="3"
                FontSize="10"
                Text="{l:Translate DeleteCategoryHelp}"
                TextColor="{DynamicResource AppMutedText}" />
        </Grid>
    </Border>

</toolkit:Popup>
