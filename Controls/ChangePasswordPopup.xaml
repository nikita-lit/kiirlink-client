<?xml version="1.0" encoding="utf-8"?>

<toolkit:Popup
    x:Class="KiirLink.Controls.ChangePasswordPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:KiirLink.Extensions"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="Transparent"
    CanBeDismissedByTappingOutsideOfPopup="True"
    Padding="0">

    <Border
        Padding="14"
        Stroke="{DynamicResource AppStroke}"
        StrokeShape="RoundRectangle 14"
        BackgroundColor="{DynamicResource AppSurface}">
        <VerticalStackLayout Spacing="12" WidthRequest="320">
            <Label
                FontFamily="RadioCanadaBigSemiBold"
                FontSize="16"
                Text="{l:Translate ChangePassword}"
                TextColor="{DynamicResource AppText}" />

            <Entry
                x:Name="CurrentPasswordEntry"
                IsPassword="True"
                Placeholder="{l:Translate CurrentPassword}"
                ReturnType="Next" />

            <Entry
                x:Name="NewPasswordEntry"
                IsPassword="True"
                Placeholder="{l:Translate NewPassword}"
                ReturnType="Next" />

            <Entry
                x:Name="ConfirmPasswordEntry"
                IsPassword="True"
                Placeholder="{l:Translate ConfirmNewPassword}"
                ReturnType="Done" />

            <Label
                x:Name="ErrorLabel"
                FontSize="11"
                IsVisible="False"
                LineBreakMode="WordWrap"
                TextColor="{DynamicResource AppDangerText}" />

            <ActivityIndicator
                x:Name="LoadingIndicator"
                IsVisible="False"
                HorizontalOptions="Center" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button
                    Clicked="OnCancelClicked"
                    Style="{StaticResource OutlineButton}"
                    Text="{l:Translate Cancel}" />
                <Button
                    x:Name="SaveButton"
                    Grid.Column="1"
                    Clicked="OnSaveClicked"
                    Style="{StaticResource PrimaryButton}"
                    Text="{l:Translate ChangePassword}" />
            </Grid>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
