<?xml version="1.0" encoding="utf-8"?>

<ContentView
    x:Class="KiirLink.Controls.BottomNavigation"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:KiirLink.Extensions">

    <Border
        Margin="24,6,24,12"
        Padding="8,4"
        Style="{StaticResource CardBorder}">
        <Grid ColumnDefinitions="*,*,*,*" HeightRequest="34">
            <Grid Grid.Column="0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer CommandParameter="Home" Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Image
                    x:Name="HomeIcon"
                    HeightRequest="29"
                    HorizontalOptions="Center"
                    InputTransparent="True"
                    Source="hometab.png"
                    VerticalOptions="Center"
                    WidthRequest="29" />
                <Button
                    AutomationProperties.IsInAccessibleTree="True"
                    SemanticProperties.Description="{l:Translate Home}"
                    BackgroundColor="Transparent"
                    Clicked="OnTabClicked"
                    CommandParameter="Home"
                    Opacity="0.01" />
            </Grid>

            <Grid Grid.Column="1">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer CommandParameter="Links" Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Image
                    x:Name="LinksIcon"
                    HeightRequest="29"
                    HorizontalOptions="Center"
                    InputTransparent="True"
                    Source="linkstab.png"
                    VerticalOptions="Center"
                    WidthRequest="29" />
                <Button
                    AutomationProperties.IsInAccessibleTree="True"
                    SemanticProperties.Description="{l:Translate Links}"
                    BackgroundColor="Transparent"
                    Clicked="OnTabClicked"
                    CommandParameter="Links"
                    Opacity="0.01" />
            </Grid>

            <Grid Grid.Column="2">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer CommandParameter="Favourites" Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Image
                    x:Name="FavouritesIcon"
                    HeightRequest="29"
                    HorizontalOptions="Center"
                    InputTransparent="True"
                    Source="startab.png"
                    VerticalOptions="Center"
                    WidthRequest="29" />
                <Button
                    AutomationProperties.IsInAccessibleTree="True"
                    SemanticProperties.Description="{l:Translate Favourites}"
                    BackgroundColor="Transparent"
                    Clicked="OnTabClicked"
                    CommandParameter="Favourites"
                    Opacity="0.01" />
            </Grid>

            <Grid Grid.Column="3">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer CommandParameter="Profile" Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Image
                    x:Name="ProfileIcon"
                    HeightRequest="29"
                    HorizontalOptions="Center"
                    InputTransparent="True"
                    Source="usertab.png"
                    VerticalOptions="Center"
                    WidthRequest="29" />
                <Button
                    AutomationProperties.IsInAccessibleTree="True"
                    SemanticProperties.Description="{l:Translate Profile}"
                    BackgroundColor="Transparent"
                    Clicked="OnTabClicked"
                    CommandParameter="Profile"
                    Opacity="0.01" />
            </Grid>
        </Grid>
    </Border>

</ContentView>
