<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.CreateAccountPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Create account">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="24,28"
                Spacing="18"
                VerticalOptions="Center">

                <VerticalStackLayout Spacing="10">
                    <Image
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        Source="kiirlink_logo.png"
                        WidthRequest="72" />
                    <Label
                        HorizontalTextAlignment="Center"
                        FontFamily="RadioCanadaBigSemiBold"
                        FontSize="24"
                        Text="Create account" />
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabel}"
                        Text="Make a new KiirLink account." />
                </VerticalStackLayout>

                <Border Padding="16" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="11" Text="Email" />
                            <Entry x:Name="EmailEntry" Keyboard="Email" Placeholder="you@example.com" ReturnType="Next" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="11" Text="Password" />
                            <Entry x:Name="PasswordEntry" IsPassword="True" Placeholder="Password" ReturnType="Next" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="11" Text="Confirm password" />
                            <Entry x:Name="ConfirmPasswordEntry" IsPassword="True" Placeholder="Repeat password"
                                   ReturnType="Done" />
                        </VerticalStackLayout>

                        <Button
                            x:Name="CreateAccountButton"
                            Clicked="OnCreateAccountClicked"
                            Style="{StaticResource PrimaryButton}"
                            Text="CREATE ACCOUNT" />

                        <Button
                            Clicked="OnBackToSignInClicked"
                            Style="{StaticResource OutlineButton}"
                            Text="BACK TO SIGN IN" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Label
            Grid.Row="1"
            Margin="24,0,24,18"
            HorizontalTextAlignment="Center"
            Style="{StaticResource MutedLabel}"
            Text="Protected workspace" />
    </Grid>
</ContentPage>