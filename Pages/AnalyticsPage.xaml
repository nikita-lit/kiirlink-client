<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    xmlns:models="clr-namespace:KiirLink.Models"
    Title="Analytics">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,8,24,18" Spacing="12">
                <controls:AppHeader />

                <!--  Top link card  -->
                <controls:LinkCard
                    x:Name="TopLinkCard"
                    Category="—"
                    Date="—"
                    CategoryRequested="OnTopLinkCategoryRequested"
                    CategoryDeleteRequested="OnTopLinkCategoryDeleteRequested"
                    Title="—"
                    Views="—" />

                <!--  Stats: views / clicks / favourites  -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" Padding="10" Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="-1">
                            <Border
                                BackgroundColor="{StaticResource SoftOrange}"
                                HeightRequest="24"
                                HorizontalOptions="Start"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="24">
                                <Label
                                    HorizontalTextAlignment="Center"
                                    Text="⊙"
                                    TextColor="{StaticResource BrandOrange}"
                                    VerticalTextAlignment="Center" />
                            </Border>
                            <Label x:Name="ViewsLabel" FontFamily="RadioCanadaBigSemiBold" FontSize="22" Text="—" />
                            <Label Style="{StaticResource MutedLabel}" Text="views" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Padding="10" Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="-1">
                            <Border
                                BackgroundColor="{StaticResource SoftOrange}"
                                HeightRequest="24"
                                HorizontalOptions="Start"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="24">
                                <Label
                                    HorizontalTextAlignment="Center"
                                    Text="↗"
                                    TextColor="{StaticResource BrandOrange}"
                                    VerticalTextAlignment="Center" />
                            </Border>
                            <Label x:Name="ClicksLabel" FontFamily="RadioCanadaBigSemiBold" FontSize="22" Text="—" />
                            <Label Style="{StaticResource MutedLabel}" Text="clicks" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Padding="10" Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="-1">
                            <Border
                                BackgroundColor="{StaticResource SoftOrange}"
                                HeightRequest="24"
                                HorizontalOptions="Start"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="24">
                                <Label
                                    HorizontalTextAlignment="Center"
                                    Text="♥"
                                    TextColor="{StaticResource BrandOrange}"
                                    VerticalTextAlignment="Center" />
                            </Border>
                            <Label x:Name="FavouritesLabel" FontFamily="RadioCanadaBigSemiBold" FontSize="22" Text="—" />
                            <Label Style="{StaticResource MutedLabel}" Text="favourites" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!--  Performance chart  -->
                <Label Style="{StaticResource SectionTitle}" Text="Performance" />
                <Border Padding="8" Style="{StaticResource CardBorder}">
                    <GraphicsView x:Name="PerformanceChart" HeightRequest="132" />
                </Border>

                <!--  Traffic sources  -->
                <Label Style="{StaticResource SectionTitle}" Text="Traffic sources" />
                <Border x:Name="SourcesCard" Padding="12,10" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout x:Name="SourcesLayout" Spacing="12" />
                </Border>

                <!--  Recent activity  -->
                <Label Style="{StaticResource SectionTitle}" Text="Recent activity" />
                <Border Padding="12,0" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout x:Name="ActivityLayout" Spacing="0" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Links" />
    </Grid>

</ContentPage>