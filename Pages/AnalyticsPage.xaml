<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    xmlns:l="clr-namespace:KiirLink.Extensions"
    xmlns:models="clr-namespace:KiirLink.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="{DynamicResource AppBackground}"
    Title="{l:Translate Analytics}">

    <Grid BackgroundColor="{DynamicResource AppBackground}" RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="{StaticResource PagePadding}" Spacing="12">
                <controls:AppHeader />

                <!--  Top link card  -->
                <controls:LinkCard
                    x:Name="TopLinkCard"
                    Category="—"
                    Date="—"
                    ShowActions="False"
                    ShowFavouriteIndicator="False"
                    Title="—"
                    Clicks="0" />

                <!--  Stats: clicks / favourites  -->
                <Grid ColumnDefinitions="*" ColumnSpacing="10">
                    <Border Grid.Column="0" Padding="10" Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="-1">
                            <Border
                                BackgroundColor="{DynamicResource AppAccentSurface}"
                                HeightRequest="24"
                                HorizontalOptions="Start"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="24">
                                <Image
                                    HeightRequest="16"
                                    Source="click.svg"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{DynamicResource AppAccentText}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            <Label x:Name="ClicksLabel" FontFamily="RadioCanadaBigSemiBold" FontSize="22" Text="—" />
                            <Label Style="{StaticResource MutedLabel}" Text="{l:Translate Clicks}" />
                        </VerticalStackLayout>
                    </Border>
                    <!--
                    <Border Grid.Column="1" Padding="10" Style="{StaticResource CardBorder}">
                        <VerticalStackLayout Spacing="-1">
                            <Border
                                BackgroundColor="{DynamicResource AppAccentSurface}"
                                HeightRequest="24"
                                HorizontalOptions="Start"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="24">
                                <Image
                                    HeightRequest="16"
                                    Source="like.svg"
                                    WidthRequest="16">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{DynamicResource AppAccentText}" />
                                    </Image.Behaviors>
                                </Image>
                            </Border>
                            <Label x:Name="FavouritesLabel" FontFamily="RadioCanadaBigSemiBold" FontSize="22" Text="—" />
                            <Label Style="{StaticResource MutedLabel}" Text="favourites" />
                        </VerticalStackLayout>
                    </Border>-->
                </Grid>

                <Border
                    x:Name="NoStatisticsBanner"
                    Padding="12"
                    BackgroundColor="{DynamicResource AppAccentSurface}"
                    IsVisible="False"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 12">
                    <Label
                        x:Name="NoStatisticsLabel"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabel}"
                        Text="{l:Translate NoStatistics}" />
                </Border>

                <!--  Performance chart  -->
                <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Performance}" />
                <Border Padding="8" Style="{StaticResource CardBorder}">
                    <Grid HeightRequest="132">
                        <GraphicsView x:Name="PerformanceChart" />
                        <Label
                            x:Name="PerformanceEmptyLabel"
                            HorizontalTextAlignment="Center"
                            IsVisible="False"
                            Style="{StaticResource MutedLabel}"
                            Text="{l:Translate NoPerformanceData}"
                            VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <!--  Countries  -->
                <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Countries}" />
                <Border x:Name="CountriesCard" Padding="12,10" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout x:Name="CountriesLayout" Spacing="12" />
                </Border>

                <!--  Recent activity  -->
                <Label Style="{StaticResource SectionTitle}" Text="{l:Translate RecentActivity}" />
                <Border Padding="12,0" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout x:Name="ActivityLayout" Spacing="0" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Links" />
    </Grid>

</ContentPage>
