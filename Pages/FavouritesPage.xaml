<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.FavouritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    xmlns:models="clr-namespace:KiirLink.Models"
    Title="Favourites">

    <Grid RowDefinitions="*,Auto">
        <Grid
            Grid.Row="0"
            Padding="24,8,24,10"
            RowDefinitions="Auto,Auto,Auto,*"
            RowSpacing="12">
            <controls:AppHeader Grid.Row="0" />

            <Border Grid.Row="1" Padding="16,13" Style="{StaticResource CardBorder}">
                <HorizontalStackLayout Spacing="14">
                    <Border
                        BackgroundColor="{StaticResource SoftRed}"
                        HeightRequest="44"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        WidthRequest="44">
                        <Image
                            HeightRequest="35"
                            HorizontalOptions="Center"
                            Source="like.png"
                            VerticalOptions="Center"
                            WidthRequest="35" />
                    </Border>
                    <VerticalStackLayout Spacing="-3" VerticalOptions="Center">
                        <Label
                            x:Name="FavCountLabel"
                            FontFamily="RadioCanadaBigSemiBold"
                            FontSize="30"
                            Text="0" />
                        <Label FontFamily="RadioCanadaBigSemiBold" FontSize="11" Text="favourites"
                               TextColor="{StaticResource BrandText}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <Label
                Grid.Row="2"
                Style="{StaticResource SectionTitle}"
                Text="My favourites" />

            <CollectionView
                x:Name="FavouritesCollection"
                Grid.Row="3"
                ItemsSource="{Binding Favourites}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LinkModel">
                        <controls:LinkCard
                            CardTapped="OnLinkCardTapped"
                            AnalyticsRequested="OnLinkAnalyticsRequested"
                            CategoryRequested="OnLinkCategoryRequested"
                            CategoryDeleteRequested="OnLinkCategoryDeleteRequested"
                            FavouriteToggleRequested="OnLinkFavouriteToggleRequested"
                            DeleteRequested="OnLinkDeleteRequested"
                            Category="{Binding CategoryName}"
                            Date="{Binding DisplayDate}"
                            IsFavourite="True"
                            LinkId="{Binding ResolvedId}"
                            ShortUrl="{Binding ShortUrl}"
                            Title="{Binding DisplayTitle}"
                            Url="{Binding OriginalUrl}"
                            Views="{Binding DisplayViews}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label
                        Margin="0,24"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabel}"
                        Text="No favourites yet." />
                </CollectionView.EmptyView>
            </CollectionView>
        </Grid>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Favourites" />
    </Grid>

</ContentPage>