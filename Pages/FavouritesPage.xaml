<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.FavouritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    xmlns:l="clr-namespace:KiirLink.Extensions"
    xmlns:models="clr-namespace:KiirLink.Models"
    xmlns:models1="clr-namespace:KiirLink.Models;assembly=KiirLink.Core"
    BackgroundColor="{DynamicResource AppBackground}"
    Title="{l:Translate Favourites}">

    <Grid BackgroundColor="{DynamicResource AppBackground}" RowDefinitions="*,Auto">
        <Grid
            Grid.Row="0"
            Padding="{StaticResource PagePadding}"
            RowDefinitions="Auto,Auto,Auto,*"
            RowSpacing="12">
            <controls:AppHeader Grid.Row="0" />

            <Border Grid.Row="1" Padding="16,13" Style="{StaticResource CardBorder}">
                <HorizontalStackLayout Spacing="14">
                    <Border
                        BackgroundColor="{DynamicResource AppDangerSurface}"
                        HeightRequest="44"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 22"
                        WidthRequest="44">
                        <Image
                            HeightRequest="35"
                            HorizontalOptions="Center"
                            Source="like.png"
                            SemanticProperties.Description="Favourites"
                            VerticalOptions="Center"
                            WidthRequest="35" />
                    </Border>
                    <VerticalStackLayout Spacing="-3" VerticalOptions="Center">
                        <Label
                            x:Name="FavCountLabel"
                            FontFamily="RadioCanadaBigSemiBold"
                            FontSize="30"
                            Text="0" />
                        <Label FontFamily="RadioCanadaBigSemiBold" FontSize="11" Text="{l:Translate Favourites}"
                               TextColor="{DynamicResource AppText}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <Label
                Grid.Row="2"
                Style="{StaticResource SectionTitle}"
                Text="{l:Translate MyFavourites}" />

            <CollectionView
                x:Name="FavouritesCollection"
                Grid.Row="3"
                ItemsSource="{Binding Favourites}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LinkModel">
                        <controls:LinkCard
                            CardTapped="OnLinkCardTapped"
                            AnalyticsRequested="OnLinkAnalyticsRequested"
                            CategoryRequested="OnLinkCategoryRequested"
                            FavouriteToggleRequested="OnLinkFavouriteToggleRequested"
                            DeleteRequested="OnLinkDeleteRequested"
                            QRCodeRequested="OnCreateQRCodeClicked"
                            Category="{Binding CategoryName}"
                            Date="{Binding DisplayDate}"
                            ExpiresAt="{Binding ExpiresAt}"
                            IsFavourite="True"
                            IsPublic="{Binding IsPublic}"
                            LinkId="{Binding ResolvedId}"
                            ShortUrl="{Binding ShortUrl}"
                            Title="{Binding DisplayTitle}"
                            Url="{Binding OriginalUrl}"
                            Clicks="{Binding Clicks}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label
                        Margin="0,24"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabel}"
                        Text="{l:Translate NoFavouritesYet}" />
                </CollectionView.EmptyView>
            </CollectionView>

            <ActivityIndicator
                x:Name="LoadingIndicator"
                Grid.Row="3"
                IsVisible="False"
                VerticalOptions="Center"
                SemanticProperties.Description="Loading favourites" />

            <Border
                x:Name="OfflineBanner"
                Grid.Row="3"
                IsVisible="False"
                Style="{StaticResource OfflineBanner}"
                VerticalOptions="Start">
                <Label HorizontalTextAlignment="Center" Text="{l:Translate NoInternetConnection}"
                       TextColor="{DynamicResource AppDangerText}" />
            </Border>
        </Grid>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Favourites" />
    </Grid>

</ContentPage>
