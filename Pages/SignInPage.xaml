<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.SignInPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:KiirLink.ViewModels"
    x:DataType="viewModels:SignInViewModel"
    BackgroundColor="{DynamicResource AppBackground}"
    Title="Sign in">

    <Grid BackgroundColor="{DynamicResource AppBackground}" RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="{StaticResource PagePadding}"
                Spacing="18"
                VerticalOptions="Center">

                <VerticalStackLayout Spacing="10">
                    <Image
                        HeightRequest="72"
                        HorizontalOptions="Center"
                        Source="kiirlink_logo.png"
                        WidthRequest="72"
                        SemanticProperties.Description="KiirLink logo" />
                    <Label
                        HorizontalTextAlignment="Center"
                        FontFamily="RadioCanadaBigSemiBold"
                        FontSize="24"
                        Text="KiirLink" />
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabel}"
                        Text="Sign in to manage your links." />
                </VerticalStackLayout>

                <Border Padding="{StaticResource CardPadding}" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="11" Text="Email" />
                            <Entry Keyboard="Email" Placeholder="you@example.com" ReturnType="Next"
                                   Text="{Binding Email}" SemanticProperties.Description="Email address" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label FontSize="11" Text="Password" />
                            <Entry IsPassword="True" Placeholder="Password" ReturnType="Done"
                                   Text="{Binding Password}" SemanticProperties.Description="Password" />
                        </VerticalStackLayout>

                        <Button
                            Command="{Binding SignInCommand}"
                            IsEnabled="{Binding CanInteract}"
                            Style="{StaticResource PrimaryButton}"
                            Text="SIGN IN"
                            SemanticProperties.Description="Sign in to KiirLink" />

                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                           SemanticProperties.Description="Signing in" />

                        <Button
                            Command="{Binding CreateAccountCommand}"
                            Style="{StaticResource OutlineButton}"
                            Text="CREATE ACCOUNT" />
                    </VerticalStackLayout>
                </Border>

                <Border IsVisible="{Binding IsOffline}" Style="{StaticResource OfflineBanner}">
                    <Label HorizontalTextAlignment="Center" Text="No internet connection"
                           TextColor="{DynamicResource AppDangerText}" />
                </Border>

                <Label
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource MutedLabel}"
                    Text="Use your KiirLink account to continue." />
            </VerticalStackLayout>
        </ScrollView>

        <Label
            Grid.Row="1"
            Margin="24,0,24,18"
            HorizontalTextAlignment="Center"
            Style="{StaticResource MutedLabel}"
            Text="KiirLink Team" />
    </Grid>
</ContentPage>
