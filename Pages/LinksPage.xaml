<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.LinksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    xmlns:l="clr-namespace:KiirLink.Extensions"
    xmlns:models="clr-namespace:KiirLink.Models"
    xmlns:models1="clr-namespace:KiirLink.Models;assembly=KiirLink.Core"
    BackgroundColor="{DynamicResource AppBackground}"
    Title="{l:Translate Links}">

    <Grid BackgroundColor="{DynamicResource AppBackground}" RowDefinitions="*,Auto">
        <Grid
            Grid.Row="0"
            Padding="{StaticResource PagePadding}"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
            RowSpacing="12">
            <controls:AppHeader Grid.Row="0" />

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource SectionTitle}" Text="{l:Translate PopularLink}" VerticalTextAlignment="Center" />
                <Button
                    Grid.Column="1"
                    Clicked="OnManageCategoriesClicked"
                    Style="{StaticResource OutlineButton}"
                    Text="{l:Translate Categories}" />
                <Button
                    Grid.Column="2"
                    Clicked="OnNewLinkClicked"
                    ContentLayout="Left,6"
                    ImageSource="plus.png"
                    Style="{StaticResource PrimaryButton}"
                    Text="{l:Translate NewLink}"
                    AutomationProperties.IsInAccessibleTree="True"
                    SemanticProperties.Description="Create a new short link" />
            </Grid>

            <!--  Popular link card (top link by views)  -->
            <Border
                x:Name="PopularCard"
                Grid.Row="2"
                IsVisible="False"
                Padding="{StaticResource CardPadding}"
                Style="{StaticResource CardBorder}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAnalyticsTapped" />
                </Border.GestureRecognizers>
                <Grid
                    ColumnDefinitions="*,Auto"
                    RowDefinitions="Auto,Auto,Auto"
                    RowSpacing="4">
                    <HorizontalStackLayout Spacing="4">
                        <Label
                            x:Name="PopularViews"
                            FontFamily="RadioCanadaBigSemiBold"
                            FontSize="31"
                            Text="0" />
                        <Label FontFamily="RadioCanadaBigSemiBold" FontSize="16" Text="{l:Translate Clicks}"
                               HorizontalTextAlignment="Start"
                               VerticalTextAlignment="End" />
                    </HorizontalStackLayout>
                    <Label x:Name="PopularTitle" Grid.Row="1" Style="{StaticResource CardTitle}" Text="" />
                    <Label x:Name="PopularUrl" Grid.Row="2" Style="{StaticResource MutedLabel}" Text="" />
                    <Border
                        x:Name="PopularCategoryBadge"
                        Grid.RowSpan="3"
                        Grid.Column="1"
                        BackgroundColor="{DynamicResource AppGoldSurface}"
                        Padding="8,4"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 5"
                        VerticalOptions="Center">
                        <Label x:Name="PopularCategory" FontSize="10" Text=""
                               TextColor="{DynamicResource AppGoldText}" />
                    </Border>
                </Grid>
            </Border>

            <Label Grid.Row="3" Style="{StaticResource SectionTitle}" Text="{l:Translate MyLinks}" />

            <Grid Grid.Row="4">

                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Padding="5, 0, 5, 0">
                    <HorizontalStackLayout Spacing="8">

                        <Button
                            x:Name="AllFilter"
                            Clicked="OnFilterClicked"
                            CommandParameter="0"
                            Style="{StaticResource ChipButton}"
                            Text="{l:Translate All}"
                            MinimumWidthRequest="50" />

                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Left fade -->
                <BoxView
                    HorizontalOptions="Start"
                    WidthRequest="10"
                    InputTransparent="True">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{DynamicResource AppBackground}" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Right fade -->
                <BoxView
                    HorizontalOptions="End"
                    WidthRequest="10"
                    InputTransparent="True">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="{DynamicResource AppBackground}" Offset="1" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

            </Grid>

            <!--  Links list  -->
            <CollectionView
                x:Name="LinksCollection"
                Grid.Row="5"
                ItemsSource="{Binding Links}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LinkModel">
                        <controls:LinkCard
                            CardTapped="OnLinkCardTapped"
                            AnalyticsRequested="OnLinkAnalyticsRequested"
                            FavouriteToggleRequested="OnLinkFavouriteToggleRequested"
                            CategoryRequested="OnLinkCategoryRequested"
                            DeleteRequested="OnLinkDeleteRequested"
                            QRCodeRequested="OnCreateQRCodeClicked"
                            Category="{Binding CategoryName}"
                            Date="{Binding DisplayDate}"
                            ExpiresAt="{Binding ExpiresAt}"
                            IsFavourite="{Binding IsFavourite}"
                            IsPublic="{Binding IsPublic}"
                            LinkId="{Binding Id}"
                            ShortUrl="{Binding ShortUrl}"
                            Title="{Binding DisplayTitle}"
                            Url="{Binding OriginalUrl}"
                            Clicks="{Binding Clicks}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label
                        Margin="0,24"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabel}"
                        Text="{l:Translate NoLinksFound}" />
                </CollectionView.EmptyView>
            </CollectionView>

            <ActivityIndicator
                x:Name="LoadingIndicator"
                Grid.Row="5"
                IsVisible="False"
                VerticalOptions="Center"
                SemanticProperties.Description="Loading links" />

            <VerticalStackLayout
                x:Name="LoadingSkeleton"
                Grid.Row="5"
                IsVisible="False"
                Spacing="8"
                SemanticProperties.Description="Loading link cards">
                <Border Padding="{StaticResource CardPadding}" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <BoxView BackgroundColor="{DynamicResource AppTrack}" HeightRequest="14" WidthRequest="180"
                                 HorizontalOptions="Start" />
                        <BoxView BackgroundColor="{DynamicResource AppTrack}" HeightRequest="10" />
                        <BoxView BackgroundColor="{DynamicResource AppTrack}" HeightRequest="10" WidthRequest="120"
                                 HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Border>
                <Border Padding="{StaticResource CardPadding}" Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <BoxView BackgroundColor="{DynamicResource AppTrack}" HeightRequest="14" WidthRequest="160"
                                 HorizontalOptions="Start" />
                        <BoxView BackgroundColor="{DynamicResource AppTrack}" HeightRequest="10" />
                        <BoxView BackgroundColor="{DynamicResource AppTrack}" HeightRequest="10" WidthRequest="140"
                                 HorizontalOptions="Start" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Border
                x:Name="OfflineBanner"
                Grid.Row="5"
                IsVisible="False"
                Style="{StaticResource OfflineBanner}"
                VerticalOptions="Start">
                <Label HorizontalTextAlignment="Center" Text="{l:Translate NoInternetConnection}"
                       TextColor="{DynamicResource AppDangerText}" />
            </Border>

            <!--  Pagination  -->
            <HorizontalStackLayout
                x:Name="PaginationRow"
                Grid.Row="6"
                Margin="0,4,0,2"
                HorizontalOptions="Center"
                Spacing="10" />
        </Grid>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Links" />
    </Grid>

</ContentPage>
