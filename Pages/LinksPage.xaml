<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KiirLink.Pages.LinksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    Title="Links">

    <Grid RowDefinitions="*,Auto">
        <Grid
            Grid.Row="0"
            Padding="24,8,24,10"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
            RowSpacing="12">
            <controls:AppHeader Grid.Row="0" />

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
                <Label Style="{StaticResource SectionTitle}" Text="Popular link" VerticalTextAlignment="Center" />
                <Button
                    Grid.Column="1"
                    Clicked="OnNewLinkClicked"
                    ContentLayout="Left,6"
                    ImageSource="plus.png"
                    Style="{StaticResource PrimaryButton}"
                    Text="New link" />
            </Grid>

            <Border
                Grid.Row="2"
                Padding="13,13"
                Style="{StaticResource CardBorder}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAnalyticsTapped" />
                </Border.GestureRecognizers>
                <Grid
                    ColumnDefinitions="*,Auto"
                    RowDefinitions="Auto,Auto,Auto"
                    RowSpacing="4">
                    <HorizontalStackLayout Spacing="4">
                        <Label FontFamily="RadioCanadaBigSemiBold" FontSize="31" Text="230" />
                        <Label FontFamily="RadioCanadaBigSemiBold" FontSize="9" Text="views" VerticalTextAlignment="End" />
                    </HorizontalStackLayout>
                    <Label Grid.Row="1" Style="{StaticResource CardTitle}" Text="www.kiirlink.ee/document" />
                    <Label Grid.Row="2" Style="{StaticResource MutedLabel}" Text="https://docs.google.com/forms/d/e/1FAIpQLSeE..." />
                    <Border
                        Grid.RowSpan="3"
                        Grid.Column="1"
                        BackgroundColor="{StaticResource BrandGold}"
                        Padding="8,4"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 5"
                        VerticalOptions="Center">
                        <Label FontSize="10" Text="Work" TextColor="{StaticResource White}" />
                    </Border>
                </Grid>
            </Border>

            <Label Grid.Row="3" Style="{StaticResource SectionTitle}" Text="My links" />

            <HorizontalStackLayout Grid.Row="4" Spacing="8">
                <Button
                    x:Name="AllFilter"
                    BackgroundColor="{StaticResource SoftOrange}"
                    BorderColor="{StaticResource BrandOrange}"
                    Clicked="OnFilterClicked"
                    CommandParameter="All"
                    Style="{StaticResource ChipButton}"
                    Text="All"
                    TextColor="{StaticResource BrandOrange}" />
                <Button Clicked="OnFilterClicked" CommandParameter="Work" Style="{StaticResource ChipButton}" Text="Work" />
                <Button Clicked="OnFilterClicked" CommandParameter="School" Style="{StaticResource ChipButton}" Text="School" />
                <Button Clicked="OnFilterClicked" CommandParameter="General" Style="{StaticResource ChipButton}" Text="General" />
            </HorizontalStackLayout>

            <Grid
                Grid.Row="5"
                RowDefinitions="*,*,*,*"
                RowSpacing="5">
                <controls:LinkCard Grid.Row="0" CardTapped="OnLinkCardTapped" />
                <controls:LinkCard Grid.Row="1" CardTapped="OnLinkCardTapped" />
                <controls:LinkCard Grid.Row="2" CardTapped="OnLinkCardTapped" />
                <controls:LinkCard Grid.Row="3" CardTapped="OnLinkCardTapped" />
            </Grid>

            <HorizontalStackLayout
                Grid.Row="6"
                Margin="0,4,0,2"
                HorizontalOptions="Center"
                Spacing="10">
                <Button
                    BackgroundColor="{StaticResource SoftOrange}"
                    BorderColor="{StaticResource BrandOrange}"
                    Style="{StaticResource ChipButton}"
                    Text="1"
                    TextColor="{StaticResource BrandOrange}" />
                <Button Style="{StaticResource ChipButton}" Text="2" />
                <Button Style="{StaticResource ChipButton}" Text="3" />
            </HorizontalStackLayout>
        </Grid>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Links" />
    </Grid>

</ContentPage>
