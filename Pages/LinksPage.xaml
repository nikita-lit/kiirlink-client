<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="KiirLink.Pages.LinksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KiirLink.Controls"
    xmlns:models="clr-namespace:KiirLink.Models"
    Title="Links">

    <Grid RowDefinitions="*,Auto">
        <Grid
            Grid.Row="0"
            Padding="24,8,24,10"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
            RowSpacing="12">
            <controls:AppHeader Grid.Row="0" />

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Label Style="{StaticResource SectionTitle}" Text="Popular link" VerticalTextAlignment="Center" />
                <Button
                    Grid.Column="1"
                    Clicked="OnManageCategoriesClicked"
                    Style="{StaticResource OutlineButton}"
                    Text="Categories" />
                <Button
                    Grid.Column="2"
                    Clicked="OnNewLinkClicked"
                    ContentLayout="Left,6"
                    ImageSource="plus.png"
                    Style="{StaticResource PrimaryButton}"
                    Text="New link" />
            </Grid>

            <!--  Popular link card (top link by views)  -->
            <Border
                x:Name="PopularCard"
                Grid.Row="2"
                IsVisible="False"
                Padding="13,13"
                Style="{StaticResource CardBorder}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAnalyticsTapped" />
                </Border.GestureRecognizers>
                <Grid
                    ColumnDefinitions="*,Auto"
                    RowDefinitions="Auto,Auto,Auto"
                    RowSpacing="4">
                    <HorizontalStackLayout Spacing="4">
                        <Label
                            x:Name="PopularViews"
                            FontFamily="RadioCanadaBigSemiBold"
                            FontSize="31"
                            Text="0" />
                        <Label FontFamily="RadioCanadaBigSemiBold" FontSize="9" Text="views"
                               VerticalTextAlignment="End" />
                    </HorizontalStackLayout>
                    <Label x:Name="PopularTitle" Grid.Row="1" Style="{StaticResource CardTitle}" Text="" />
                    <Label x:Name="PopularUrl" Grid.Row="2" Style="{StaticResource MutedLabel}" Text="" />
                    <Border
                        x:Name="PopularCategoryBadge"
                        Grid.RowSpan="3"
                        Grid.Column="1"
                        BackgroundColor="{StaticResource BrandGold}"
                        Padding="8,4"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 5"
                        VerticalOptions="Center">
                        <Label x:Name="PopularCategory" FontSize="10" Text="" TextColor="{StaticResource White}" />
                    </Border>
                </Grid>
            </Border>

            <!--  Empty popular card placeholder  -->
            <Border
                x:Name="PopularCardEmpty"
                Grid.Row="2"
                IsVisible="True"
                Padding="13,13"
                Style="{StaticResource CardBorder}">
                <Label
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource MutedLabel}"
                    Text="No links yet. Create your first one!" />
            </Border>

            <Label Grid.Row="3" Style="{StaticResource SectionTitle}" Text="My links" />

            <HorizontalStackLayout Grid.Row="4" Spacing="8">
                <Button
                    x:Name="AllFilter"
                    BackgroundColor="{StaticResource SoftOrange}"
                    BorderColor="{StaticResource BrandOrange}"
                    Clicked="OnFilterClicked"
                    CommandParameter="0"
                    Style="{StaticResource ChipButton}"
                    Text="All"
                    TextColor="{StaticResource BrandOrange}" />
            </HorizontalStackLayout>

            <!--  Links list  -->
            <CollectionView
                x:Name="LinksCollection"
                Grid.Row="5"
                ItemsSource="{Binding Links}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="5" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:LinkModel">
                        <controls:LinkCard
                            CardTapped="OnLinkCardTapped"
                            AnalyticsRequested="OnLinkAnalyticsRequested"
                            FavouriteToggleRequested="OnLinkFavouriteToggleRequested"
                            CategoryRequested="OnLinkCategoryRequested"
                            CategoryDeleteRequested="OnLinkCategoryDeleteRequested"
                            DeleteRequested="OnLinkDeleteRequested"
                            Category="{Binding CategoryName}"
                            Date="{Binding DisplayDate}"
                            LinkId="{Binding Id}"
                            ShortUrl="{Binding ShortUrl}"
                            Title="{Binding DisplayTitle}"
                            Url="{Binding OriginalUrl}"
                            Views="{Binding DisplayViews}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label
                        Margin="0,24"
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource MutedLabel}"
                        Text="No links found." />
                </CollectionView.EmptyView>
            </CollectionView>

            <!--  Pagination  -->
            <HorizontalStackLayout
                x:Name="PaginationRow"
                Grid.Row="6"
                Margin="0,4,0,2"
                HorizontalOptions="Center"
                Spacing="10" />
        </Grid>

        <controls:BottomNavigation Grid.Row="1" ActiveTab="Links" />
    </Grid>

</ContentPage>